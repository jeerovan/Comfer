<resources>
    <string name="app_name">Comfer</string>
    <string name="welcome">வரவேற்கிறோம்</string>

    <string name="checkout_how_to_guide">
        மெனுவை திறக்கவும் “எப்படி செய்வது” வழிகாட்டியை பார்க்கவும், திரையின் கீழ் பகுதியை நீண்ட நேரம் அழுத்தவும்。\nகுறிப்பு: சில மொழிபெயர்ப்புகள் தானாக உருவாக்கப்பட்டிருக்கலாம். தவறான உரை இருப்பின் தயவுசெய்து எங்களை மின்னஞ்சல் மூலம் தொடர்புகொள்ளுங்கள்.
    </string>

    <string name="accessibility_service_description">
        கணினி அமைப்பின் “சமீபத்திய பயன்பாடுகள்” திரையை திறக்க இந்த அணுகல் சேவை தேவை. Comfer இந்த அனுமதியை குறுக்குவழி வழங்குவதற்காக மட்டுமே பயன்படுத்துகிறது மற்றும் எந்த தனிப்பட்ட தரவையும் சேகரிக்கவோ கண்காணிக்கவோாது.
    </string>

