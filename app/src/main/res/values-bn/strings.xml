    <string name="checkout_how_to_guide">
        মেনু খুলতে এবং “কীভাবে করবেন” গাইড দেখতে স্ক্রিনের নিচের অর্ধেক অংশে দীর্ঘক্ষণ চাপ দিন。\nদায়বদ্ধতা: কিছু অনুবাদ স্বয়ংক্রিয়ভাবে তৈরি হতে পারে। কোনো ভুল লেখা চোখে পড়লে অনুগ্রহ করে ইমেইলের মাধ্যমে আমাদের জানান।
    </string>

    <string name="accessibility_service_description">
        সিস্টেমের “সাম্প্রতিক অ্যাপস” স্ক্রিন খুলতে এই অ্যাক্সেসিবিলিটি সার্ভিসটি প্রয়োজন। Comfer এই অনুমতিটি শুধুমাত্র শর্টকাট সুবিধা দেওয়ার জন্য ব্যবহার করে এবং কোনো ব্যক্তিগত তথ্য সংগ্রহ বা পর্যবেক্ষণ করে না।
    </string>

